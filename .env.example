APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# API Proveedor (Alan Osorio)
PROVEEDOR_API_URL=http://54.210.85.103:7190/api
PROVEEDOR_API_CONNECT_TIMEOUT=5
PROVEEDOR_API_TIMEOUT=15
PROVEEDOR_API_MAX_RETRIES=3
PROVEEDOR_LOGIN_MODE=fallback

# API Cliente (misma API de Alan, ctipocliente=1)
CLIENTE_API_URL=http://54.210.85.103:7190/api
CLIENTE_API_CONNECT_TIMEOUT=5
CLIENTE_API_TIMEOUT=15
CLIENTE_API_MAX_RETRIES=3
CLIENTE_LOGIN_MODE=fallback

# IA — Amazon Bedrock (Claude via AWS)
IA_PROVIDER=bedrock
IA_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
IA_BEDROCK_REGION=us-east-1
IA_AWS_ACCESS_KEY=
IA_AWS_SECRET_KEY=
IA_TIMEOUT=60

# Anthropic Claude (fallback directo, si no usas Bedrock)
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIMEOUT=60

# Groq AI (respaldo)
GROQ_API_KEY=

# API interna Salcom (para MCP / Kiro)
SALCOM_API_TOKEN=salcom-kiro-2026-secret
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=30

# Rate Limiting Login
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_SECONDS=60

# ── Gmail SMTP ──
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=tu-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tu-correo@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Twilio (WhatsApp Business API) ──
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Validación RFC ante SAT ──
SAT_RFC_VALIDATION_URL=https://api.el-sat.com/v1
SAT_API_KEY=
SAT_TIMEOUT=10

# ── PAC para timbrado CFDI ──
PAC_DRIVER=facturama
PAC_API_URL=https://apisandbox.facturama.mx
PAC_API_USER=
PAC_API_PASSWORD=
PAC_SANDBOX=true
PAC_TIMEOUT=30

# ── Paqueterías (tracking opcional) ──
ESTAFETA_API_URL=
ESTAFETA_API_KEY=
DHL_API_URL=https://api-eu.dhl.com/track/shipments
DHL_API_KEY=
FEDEX_API_URL=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
